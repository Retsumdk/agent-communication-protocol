{
  "name": "@retsumdk/agent-communication-protocol",
  "version": "1.0.0",
  "description": "Inter-agent message passing protocol with delivery guarantees, acknowledgment receipts, and priority queuing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "acp": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "test": "bun test",
    "cli": "bun run src/index.ts",
    "send": "bun run src/index.ts send",
    "ack": "bun run src/index.ts ack",
    "status": "bun run src/index.ts status",
    "stats": "bun run src/index.ts stats"
  },
  "keywords": [
    "ai-agent",
    "multi-agent",
    "agent-communication",
    "message-passing",
    "agent-protocol",
    "distributed-systems"
  ],
  "author": "Retsumdk",
  "license": "MIT",
  "devDependencies": {
    "bun-types": "^1.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0"
  }
}